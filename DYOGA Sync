    document.getElementById('hrvNum').textContent = Math.round(state.hrv);
    document.getElementById('ppgVal').textContent = Math.round(state.hrv) + 'ms';
    document.getElementById('ppgBar').style.width = Math.min(100, state.hrv * 1.5) + '%';
    const status = state.hrv > 55 ? 'Good' : state.hrv > 42 ? 'Moderate' : 'Low';
    document.getElementById('hrvStatus').textContent = status;
    hrvHistory.push(Math.round(state.hrv)); hrvHistory.shift();
    drawHRVChart();

    // BPM
    state.bpm = Math.max(58, Math.min(82, state.bpm + Math.round((Math.random()-0.5)*4)));
    document.getElementById('bpmLive').textContent = '♥ ' + state.bpm + ' bpm';

    // Temp
    state.temp = Math.max(36.2, Math.min(37.4, state.temp + (Math.random()-0.5)*0.08));
    document.getElementById('tempVal').textContent = state.temp.toFixed(1) + '°';

    // EDA
    state.eda = Math.max(0.5, Math.min(8, state.eda + (Math.random()-0.5)*0.4));
    document.getElementById('edaVal').textContent = state.eda.toFixed(1) + 'μS';
    document.getElementById('edaBar').style.width = Math.min(100, state.eda * 12) + '%';
    document.getElementById('edaBar').parentElement.nextElementSibling.children[0].textContent = state.eda.toFixed(1) + 'μS';

    // Accel
    state.accel = Math.max(0.1, Math.min(2, state.accel + (Math.random()-0.5)*0.15));
    document.getElementById('accelVal').textContent = state.accel.toFixed(2) + 'g';
    document.getElementById('accelBar').style.width = Math.min(100, state.accel * 50) + '%';

    // Signal
    state.signal = Math.max(-70, Math.min(-30, state.signal + Math.round((Math.random()-0.5)*4)));
    document.getElementById('signalVal').textContent = state.signal;
    signalHistory.push(state.signal); signalHistory.shift();
    drawSignalChart();

    // Scores drift
    state.calm = Math.max(60, Math.min(100, state.calm + (Math.random()-0.5)*2));
    state.focus = Math.max(55, Math.min(100, state.focus + (Math.random()-0.5)*2));
    state.nsScore = Math.round((state.calm + state.focus + state.rec + state.emo) / 4);
    document.getElementById('nsScore').textContent = state.nsScore;
    document.getElementById('calmVal').textContent = Math.round(state.calm);
    document.getElementById('focusVal').textContent = Math.round(state.focus);

    // NS arc update
    const pct = state.nsScore / 100;
    const circumference = 377;
    document.getElementById('nsArc').setAttribute('stroke-dashoffset', circumference * (1-pct));

    // BW
    bwHistory.push(Math.max(40,Math.min(100,bwHistory[bwHistory.length-1]+(Math.random()-0.5)*3)));
    bwHistory.shift();
    const bwCurr = Math.round(bwHistory[bwHistory.length-1]);
    document.getElementById('bwPct').innerHTML = bwCurr + '<span style="font-size:16px;">%</span>';
    document.getElementById('bwBar').style.width = bwCurr + '%';
    drawBWChart();

  }, 2000);
}

// ── CHARTS ─────────────────────────────────────────────────────
function drawSparkline(canvasId, data, color, fillColor, min, max) {
  const canvas = document.getElementById(canvasId);
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const dpr = window.devicePixelRatio || 1;
  const w = canvas.offsetWidth; const h = canvas.height;
  canvas.width = w * dpr; canvas.height = h * dpr;
  ctx.scale(dpr, dpr);
  ctx.clearRect(0, 0, w, h);

  const pad = 8;
  ctx.beginPath();
  data.forEach((v, i) => {
    const x = pad + (i / (data.length - 1)) * (w - pad * 2);
    const y = h - pad - ((v - min) / (max - min)) * (h - pad * 2);
    i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
  });
  ctx.strokeStyle = color; ctx.lineWidth = 2; ctx.lineJoin = 'round'; ctx.stroke();

  // Fill
  const lastX = pad + ((data.length-1)/(data.length-1))*(w-pad*2);
  const firstX = pad;
  ctx.lineTo(lastX, h); ctx.lineTo(firstX, h); ctx.closePath();
  const grad = ctx.createLinearGradient(0, 0, 0, h);
  grad.addColorStop(0, fillColor); grad.addColorStop(1, 'rgba(0,0,0,0)');
  ctx.fillStyle = grad; ctx.fill();
}

function drawHRVChart() { drawSparkline('hrvChart', hrvHistory, '#00e5b4', 'rgba(0,229,180,0.12)', 35, 75); }
function drawBWChart() { drawSparkline('bwChart', bwHistory, '#f5a623', 'rgba(245,166,35,0.1)', 30, 100); }

function drawSensorHistory() {
  const canvas = document.getElementById('sensorHistoryChart');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const dpr = window.devicePixelRatio || 1;
  const w = canvas.offsetWidth; const h = canvas.height;
  canvas.width = w * dpr; canvas.height = h * dpr;
  ctx.scale(dpr, dpr);
  ctx.clearRect(0,0,w,h);

  const datasets = [
    { data:[44,50,48,52,55,59,57,54,56,52,54,58,56,54,58,62,59,54,56,54,58,55,54,52], color:'#00e5b4' },
    { data:[36.7,36.8,36.9,36.8,37.0,36.9,36.8,36.7,36.8,36.9,36.8,36.7,36.8,36.8,36.9,37.0,36.9,36.8,36.7,36.8,36.8,36.9,36.8,36.8], color:'#f5a623' },
  ];
  const pad = 8;
  datasets.forEach(ds => {
    const min = Math.min(...ds.data); const max = Math.max(...ds.data);
    ctx.beginPath();
    ds.data.forEach((v, i) => {
      const x = pad + (i/(ds.data.length-1))*(w-pad*2);
      const y = h - pad - ((v-min)/(max-min+0.01))*(h-pad*2);
      i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);
    });
    ctx.strokeStyle=ds.color; ctx.lineWidth=1.5; ctx.lineJoin='round'; ctx.stroke();
  });
}

function drawSignalChart() {
  drawSparkline('signalChart', signalHistory.map(v=>Math.abs(v)), '#4fa3ff', 'rgba(79,163,255,0.08)', 25, 75);
}

function drawTeamChart() {
