// ── BREATHE ────────────────────────────────────────────────────
const protocols = {
  Box:      { phases:['Inhale','Hold','Exhale','Hold'], times:[4,4,4,4] },
  Calm:     { phases:['Inhale','Hold','Exhale'], times:[4,7,8] },
  Coherence:{ phases:['Inhale','Exhale'], times:[6,6] },
};
let currentPhaseIdx = 0, breathInterval = null, phaseInterval = null, sessionInterval = null;
let breathRunning = false;

function toggleBreath() {
  breathRunning = !breathRunning;
  const btn = document.getElementById('breathStartBtn');
  if (breathRunning) {
    btn.textContent = 'STOP SESSION';
    btn.style.borderColor = 'rgba(255,79,79,0.3)';
    btn.style.color = 'var(--red)';
    runBreathPhases();
    state.breathSeconds = 0;
    sessionInterval = setInterval(() => {
      state.breathSeconds++;
      const m = Math.floor(state.breathSeconds/60).toString().padStart(2,'0');
      const s = (state.breathSeconds%60).toString().padStart(2,'0');
      document.getElementById('sessionTime').textContent = `Session: ${m}:${s}`;
    }, 1000);
  } else {
    btn.textContent = 'START SESSION';
    btn.style.borderColor = 'rgba(0,229,180,0.3)';
    btn.style.color = 'var(--teal)';
    clearTimeout(phaseInterval); clearInterval(sessionInterval);
    document.getElementById('breathPhase').textContent = 'Inhale — 4s';
    document.getElementById('breathCount').textContent = 'Cycle 1 of 8';
    currentPhaseIdx = 0; state.breathCycle = 1;
  }
}

function runBreathPhases() {
  if (!breathRunning) return;
  const proto = protocols[state.protocol];
  const phase = proto.phases[currentPhaseIdx];
  const dur = proto.times[currentPhaseIdx];
  document.getElementById('breathPhase').textContent = `${phase} — ${dur}s`;
  currentPhaseIdx = (currentPhaseIdx + 1) % proto.phases.length;
  if (currentPhaseIdx === 0) {
    state.breathCycle = Math.min(state.breathCycle + 1, 8);
    document.getElementById('breathCount').textContent = `Cycle ${state.breathCycle} of 8`;
  }
  phaseInterval = setTimeout(runBreathPhases, dur * 1000);
}

function setProtocol(el, name, protoKey, desc) {
  document.querySelectorAll('.protocol-card').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  state.protocol = protoKey;
  if (!breathRunning) document.getElementById('breathPhase').textContent = `Inhale — ${protocols[protoKey].times[0]}s`;
}

function setSound(el) {
  el.closest('.sound-grid').querySelectorAll('.sound-card').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
}

// ── FOCUS LOCK ─────────────────────────────────────────────────
let focusInterval = null;

function toggleFocus() {
  state.focusOn = !state.focusOn;
  const btn = document.getElementById('focusBtn');
  const timer = document.getElementById('focusTimer');
  const stateEl = document.getElementById('focusState');
  const sub = document.getElementById('focusSub');

  if (state.focusOn) {
    btn.classList.add('on');
    stateEl.textContent = 'FOCUS LOCK — ACTIVE';
    sub.textContent = 'Phone silenced · Ambient sound playing · Ring monitoring fatigue level.';
    timer.style.display = 'block';
    state.focusSeconds = 0;
    focusInterval = setInterval(() => {
      state.focusSeconds++;
      const m = Math.floor(state.focusSeconds/60).toString().padStart(2,'0');
      const s = (state.focusSeconds%60).toString().padStart(2,'0');
      timer.textContent = m + ':' + s;
    }, 1000);
  } else {
    btn.classList.remove('on');
    stateEl.textContent = 'FOCUS LOCK — OFF';
    sub.textContent = 'Tap to silence notifications and activate ambient soundscape based on ring fatigue level.';
    timer.style.display = 'none';
    clearInterval(focusInterval);
  }
}

