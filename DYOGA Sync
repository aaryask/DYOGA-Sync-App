<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>DYOGA Sync</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">
<style>
/* ── RESET & TOKENS ── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:       #080b0e;
  --bg2:      #0d1117;
  --bg3:      #121820;
  --card:     #131b24;
  --card2:    #19232f;
  --teal:     #00e5b4;
  --teal2:    #00c49a;
  --teal3:    #008f70;
  --teal4:    #004d3c;
  --amber:    #f5a623;
  --amber2:   #c47d0e;
  --blue:     #4fa3ff;
  --blue2:    #1a6fcc;
  --red:      #ff4f4f;
  --red2:     #cc2222;
  --purple:   #c084fc;
  --purple2:  #8b40d4;
  --white:    #eef4f8;
  --muted:    #7a9ab0;
  --muted2:   #3d5a6e;
  --border:   rgba(0,229,180,0.1);
  --border2:  rgba(0,229,180,0.2);
  --shadow:   0 8px 32px rgba(0,0,0,0.5);
  --r:        14px;
  --r2:       10px;
  --mono:     'Space Mono', monospace;
  --sans:     'DM Sans', sans-serif;
}
html,body{height:100%;overflow:hidden;background:var(--bg);color:var(--white);font-family:var(--sans);}

/* ── LAYOUT ── */
.app-shell{display:flex;height:100vh;width:100vw;overflow:hidden;}

/* ── SIDEBAR ── */
.sidebar{
  width:72px;flex-shrink:0;background:var(--bg2);
  border-right:1px solid var(--border);
  display:flex;flex-direction:column;align-items:center;
  padding:20px 0;gap:6px;z-index:10;
  transition:width 0.3s cubic-bezier(0.4,0,0.2,1);
  overflow:hidden;
}
.sidebar.expanded{width:220px;}
.logo-mark{
  font-family:var(--mono);font-size:13px;font-weight:700;
  color:var(--teal);letter-spacing:0.15em;
  padding:10px 14px;margin-bottom:14px;
  white-space:nowrap;
}
.logo-mark span{color:var(--muted);font-weight:400;}
.nav-item{
  width:44px;height:44px;border-radius:12px;
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;transition:all 0.2s;position:relative;
  flex-shrink:0;border:none;background:none;color:var(--muted);
  text-decoration:none;
}
.sidebar.expanded .nav-item{width:192px;justify-content:flex-start;padding:0 14px;gap:12px;}
.nav-item svg{width:20px;height:20px;flex-shrink:0;}
.nav-item .nav-label{
  font-size:13px;font-family:var(--sans);color:var(--muted);
  display:none;white-space:nowrap;
}
.sidebar.expanded .nav-label{display:block;}
.nav-item:hover{background:rgba(0,229,180,0.07);color:var(--teal);}
.nav-item:hover .nav-label{color:var(--teal);}
.nav-item.active{background:rgba(0,229,180,0.12);color:var(--teal);}
.nav-item.active .nav-label{color:var(--teal);}
.nav-item .badge{
  position:absolute;top:6px;right:6px;width:8px;height:8px;
  border-radius:50%;background:var(--red);
  border:2px solid var(--bg2);
}
.sidebar.expanded .nav-item .badge{right:14px;}
.sidebar-spacer{flex:1;}
.conn-status{
  display:flex;align-items:center;gap:8px;
  padding:10px 14px;margin:0 0 8px;
  background:rgba(0,229,180,0.06);border-radius:10px;
  width:44px;overflow:hidden;transition:width 0.3s;
}
.sidebar.expanded .conn-status{width:192px;}
.conn-dot{width:8px;height:8px;border-radius:50%;background:var(--teal);flex-shrink:0;animation:pulse-glow 2s infinite;}
@keyframes pulse-glow{0%,100%{box-shadow:0 0 0 0 rgba(0,229,180,0.4);}50%{box-shadow:0 0 0 5px rgba(0,229,180,0);}}
.conn-text{font-size:10px;color:var(--teal);font-family:var(--mono);white-space:nowrap;}

/* ── MAIN AREA ── */
.main{flex:1;display:flex;flex-direction:column;overflow:hidden;position:relative;}

/* ── TOP BAR ── */
.topbar{
  height:60px;flex-shrink:0;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 24px;border-bottom:1px solid var(--border);
  background:rgba(8,11,14,0.8);backdrop-filter:blur(20px);
  z-index:5;
}
.topbar-left{display:flex;align-items:center;gap:14px;}
.menu-btn{background:none;border:none;cursor:pointer;color:var(--muted);padding:4px;border-radius:8px;display:flex;align-items:center;justify-content:center;}
.menu-btn:hover{color:var(--teal);}
.page-title{font-family:var(--mono);font-size:14px;color:var(--white);letter-spacing:0.05em;}
.topbar-right{display:flex;align-items:center;gap:12px;}
.bat-pill{
  display:flex;align-items:center;gap:6px;
  background:var(--card);border:1px solid var(--border);
  border-radius:20px;padding:4px 10px;font-size:11px;
  font-family:var(--mono);color:var(--muted);
}
.bat-icon{width:22px;height:11px;border:1.5px solid var(--muted2);border-radius:3px;position:relative;}
.bat-icon::after{content:'';position:absolute;right:-4px;top:50%;transform:translateY(-50%);width:2px;height:5px;background:var(--muted2);border-radius:0 1px 1px 0;}
.bat-fill{position:absolute;left:1px;top:1px;bottom:1px;background:var(--teal);border-radius:1.5px;transition:width 1s;}
.time-chip{font-size:11px;font-family:var(--mono);color:var(--muted);}
.notif-btn{background:none;border:none;cursor:pointer;color:var(--muted);position:relative;padding:4px;border-radius:8px;display:flex;}
.notif-btn:hover{color:var(--teal);}
.notif-btn .dot{position:absolute;top:4px;right:4px;width:6px;height:6px;border-radius:50%;background:var(--red);border:1.5px solid var(--bg);}

/* ── PANELS ── */
.panels{flex:1;overflow:hidden;position:relative;}
.panel{
  position:absolute;inset:0;overflow-y:auto;padding:24px;
  opacity:0;pointer-events:none;transform:translateY(12px);
  transition:all 0.35s cubic-bezier(0.4,0,0.2,1);
}
.panel.active{opacity:1;pointer-events:all;transform:translateY(0);}
.panel::-webkit-scrollbar{width:4px;}
.panel::-webkit-scrollbar-track{background:transparent;}
.panel::-webkit-scrollbar-thumb{background:var(--muted2);border-radius:2px;}

/* ── GRID HELPERS ── */
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;}
.grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;}

/* ── CARDS ── */
.card{
  background:var(--card);border:1px solid var(--border);
  border-radius:var(--r);padding:18px;
  transition:border-color 0.2s;
}
.card:hover{border-color:var(--border2);}
.card-sm{padding:14px;}
.section-label{
  font-family:var(--mono);font-size:10px;letter-spacing:0.12em;
  color:var(--teal);text-transform:uppercase;margin-bottom:14px;
}

/* ── RING HERO ── */
.ring-hero{
  display:flex;gap:24px;align-items:center;
  background:var(--card);border:1px solid var(--border);
  border-radius:var(--r);padding:24px;margin-bottom:14px;
  position:relative;overflow:hidden;
}
.ring-hero::before{
  content:'';position:absolute;right:-60px;top:-60px;
  width:220px;height:220px;border-radius:50%;
  background:radial-gradient(circle,rgba(0,229,180,0.06) 0%,transparent 70%);
  pointer-events:none;
}
.ring-vis{position:relative;width:140px;height:140px;flex-shrink:0;}
.ring-vis svg{width:140px;height:140px;}
.ring-center-info{
  position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  text-align:center;
}
.ns-score{font-family:var(--mono);font-size:34px;font-weight:700;color:var(--teal);line-height:1;}
.ns-label{font-size:10px;color:var(--muted);letter-spacing:0.08em;margin-top:2px;}
.ring-info{flex:1;}
.ring-name-tag{font-family:var(--mono);font-size:11px;color:var(--teal);letter-spacing:0.15em;margin-bottom:6px;}
.ring-headline{font-size:22px;font-weight:500;color:var(--white);margin-bottom:4px;}
.ring-sub{font-size:13px;color:var(--muted);margin-bottom:16px;}
.score-row{display:flex;gap:10px;flex-wrap:wrap;}
.score-chip{
  display:flex;flex-direction:column;align-items:center;
  background:var(--card2);border:1px solid var(--border);
  border-radius:10px;padding:8px 14px;min-width:72px;
}
.chip-val{font-family:var(--mono);font-size:18px;font-weight:700;line-height:1;}
.chip-label{font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:0.08em;margin-top:3px;}

/* ── HRV CARD ── */
.hrv-wrap{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;}
.hrv-number{font-family:var(--mono);font-size:28px;color:var(--teal);}
.hrv-unit{font-size:11px;color:var(--muted);margin-top:2px;}
.hrv-badge{
  font-family:var(--mono);font-size:10px;
  background:rgba(0,229,180,0.1);color:var(--teal);
  padding:3px 10px;border-radius:20px;border:1px solid rgba(0,229,180,0.2);
}
.live-tag{font-size:10px;color:var(--muted);margin-top:4px;}

/* ── INSIGHT FEED ── */
.insight{
  display:flex;align-items:center;gap:12px;
  padding:12px 14px;background:var(--card);
  border:1px solid var(--border);border-radius:var(--r2);
  margin-bottom:8px;transition:border-color 0.2s;
}
.insight:hover{border-color:var(--border2);}
.insight-icon{
  width:34px;height:34px;border-radius:10px;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.insight-icon svg{width:16px;height:16px;}
.insight-body{flex:1;}
.insight-title{font-size:13px;font-weight:500;color:var(--white);}
.insight-sub{font-size:11px;color:var(--muted);margin-top:2px;}
.insight-time{font-size:10px;color:var(--muted2);font-family:var(--mono);white-space:nowrap;}
.insight-action{
  font-size:10px;color:var(--teal);
  background:rgba(0,229,180,0.08);border:1px solid rgba(0,229,180,0.2);
  border-radius:6px;padding:3px 8px;cursor:pointer;white-space:nowrap;
  font-family:var(--mono);transition:background 0.2s;
}
.insight-action:hover{background:rgba(0,229,180,0.15);}

/* ── BREATHE PANEL ── */
.breath-stage{
  display:flex;flex-direction:column;align-items:center;
  justify-content:center;min-height:280px;
  background:var(--card);border:1px solid var(--border);
  border-radius:var(--r);margin-bottom:14px;
  position:relative;overflow:hidden;
}
.breath-stage::before{
  content:'';position:absolute;
  width:300px;height:300px;border-radius:50%;
  background:radial-gradient(circle,rgba(0,229,180,0.04) 0%,transparent 70%);
  animation:breath-bg 8s ease-in-out infinite;
}
@keyframes breath-bg{0%,100%{transform:scale(0.8);}50%{transform:scale(1.2);}}
.breath-orb-wrap{position:relative;margin-bottom:20px;}
.breath-orb{
  width:120px;height:120px;border-radius:50%;
  border:2px solid rgba(0,229,180,0.2);
  display:flex;align-items:center;justify-content:center;
  position:relative;transition:transform 4s ease-in-out;
}
.breath-orb-inner{
  width:80px;height:80px;border-radius:50%;
  background:rgba(0,229,180,0.08);
  animation:orb-breathe 8s ease-in-out infinite;
  display:flex;align-items:center;justify-content:center;
}
.breath-orb-inner svg{width:28px;height:28px;color:var(--teal);}
@keyframes orb-breathe{
  0%,100%{transform:scale(0.85);background:rgba(0,229,180,0.06);}
  50%{transform:scale(1.1);background:rgba(0,229,180,0.18);}
}
.breath-ring-1,.breath-ring-2{
  position:absolute;border-radius:50%;
  border:1px solid rgba(0,229,180,0.15);
  animation:ring-expand 8s ease-in-out infinite;
}
.breath-ring-1{width:130px;height:130px;top:-5px;left:-5px;}
.breath-ring-2{width:150px;height:150px;top:-15px;left:-15px;animation-delay:0.5s;border-color:rgba(0,229,180,0.07);}
@keyframes ring-expand{
  0%,100%{transform:scale(0.9);opacity:0.5;}
  50%{transform:scale(1.05);opacity:1;}
}
.breath-phase-text{font-family:var(--mono);font-size:16px;color:var(--teal);font-weight:700;z-index:1;}
.breath-count{font-family:var(--mono);font-size:13px;color:var(--muted);z-index:1;margin-top:4px;}
.breath-session-time{font-size:11px;color:var(--muted2);z-index:1;}
.protocol-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:14px;}
.protocol-card{
  background:var(--card);border:1px solid var(--border);
  border-radius:var(--r2);padding:14px;cursor:pointer;
  transition:all 0.2s;text-align:center;
}
.protocol-card:hover,.protocol-card.active{
  border-color:var(--teal2);background:rgba(0,229,180,0.06);
}
.proto-icon{font-size:22px;margin-bottom:6px;}
.proto-name{font-size:12px;font-weight:500;color:var(--white);}
.proto-pattern{font-size:10px;color:var(--teal);font-family:var(--mono);margin-top:2px;}
.proto-desc{font-size:10px;color:var(--muted);margin-top:4px;}

/* ── SENSORS PANEL ── */
.sensor-row{
  display:flex;align-items:center;gap:14px;
  padding:16px;background:var(--card);
  border:1px solid var(--border);border-radius:var(--r);
  margin-bottom:10px;transition:border-color 0.2s;
}
.sensor-row:hover{border-color:var(--border2);}
.sensor-icon-wrap{
  width:44px;height:44px;border-radius:12px;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.sensor-icon-wrap svg{width:20px;height:20px;}
.sensor-info{flex:1;}
.sensor-name{font-size:14px;font-weight:500;color:var(--white);}
.sensor-func{font-size:11px;color:var(--muted);margin-top:2px;}
.sensor-live{
  text-align:right;flex-shrink:0;min-width:80px;
}
.sensor-val{font-family:var(--mono);font-size:16px;font-weight:700;}
.sensor-unit{font-size:10px;color:var(--muted);margin-top:1px;}
.sensor-bar-wrap{width:100%;height:3px;background:var(--card2);border-radius:2px;margin-top:8px;overflow:hidden;}
.sensor-bar{height:100%;border-radius:2px;transition:width 1.5s ease;}

/* ── FOCUS LOCK ── */
.focus-hero{
  background:var(--card);border:1px solid var(--border);
  border-radius:var(--r);padding:24px;margin-bottom:14px;
  display:flex;gap:20px;align-items:center;
  position:relative;overflow:hidden;
}
.focus-hero::before{
  content:'';position:absolute;left:-40px;top:-40px;
  width:180px;height:180px;border-radius:50%;
  background:radial-gradient(circle,rgba(79,163,255,0.07) 0%,transparent 70%);
}
.focus-toggle-btn{
  width:72px;height:72px;border-radius:50%;
  background:var(--card2);border:2px solid var(--border2);
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;transition:all 0.3s;flex-shrink:0;
}
.focus-toggle-btn.on{
  background:rgba(79,163,255,0.15);
  border-color:var(--blue);
  box-shadow:0 0 20px rgba(79,163,255,0.2);
}
.focus-toggle-btn svg{width:28px;height:28px;color:var(--muted);}
.focus-toggle-btn.on svg{color:var(--blue);}
.focus-info{flex:1;}
.focus-state{font-family:var(--mono);font-size:11px;color:var(--muted);letter-spacing:0.12em;margin-bottom:4px;}
.focus-title{font-size:20px;font-weight:500;color:var(--white);margin-bottom:4px;}
.focus-sub{font-size:12px;color:var(--muted);}
.focus-timer{font-family:var(--mono);font-size:32px;color:var(--blue);margin-top:8px;}
.sound-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:14px;}
.sound-card{
  background:var(--card);border:1px solid var(--border);
  border-radius:10px;padding:12px;cursor:pointer;
  text-align:center;transition:all 0.2s;
}
.sound-card:hover,.sound-card.active{border-color:var(--blue2);background:rgba(79,163,255,0.06);}
.sound-icon{font-size:20px;margin-bottom:4px;}
.sound-name{font-size:11px;color:var(--white);}

/* ── SOS / SAFETY ── */
.sos-hero{
  background:rgba(255,79,79,0.05);border:1px solid rgba(255,79,79,0.2);
  border-radius:var(--r);padding:20px;margin-bottom:14px;
  display:flex;gap:16px;align-items:center;
}
.sos-indicator{
  width:52px;height:52px;border-radius:50%;
  background:rgba(255,79,79,0.12);
  border:2px solid rgba(255,79,79,0.3);
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;
}
.sos-indicator svg{width:22px;height:22px;color:var(--red);}
.sos-dot{width:8px;height:8px;border-radius:50%;background:var(--red);animation:pulse-glow-r 2s infinite;flex-shrink:0;}
@keyframes pulse-glow-r{0%,100%{box-shadow:0 0 0 0 rgba(255,79,79,0.4);}50%{box-shadow:0 0 0 5px rgba(255,79,79,0);}}
.contact-card{
  display:flex;align-items:center;gap:12px;
  padding:14px;background:var(--card);
  border:1px solid var(--border);border-radius:var(--r2);
  margin-bottom:8px;
}
.contact-av{
  width:38px;height:38px;border-radius:50%;
  background:var(--card2);display:flex;align-items:center;justify-content:center;
  font-size:13px;font-weight:500;color:var(--muted);flex-shrink:0;
  font-family:var(--mono);
}
.contact-info{flex:1;}
.contact-name{font-size:14px;font-weight:500;color:var(--white);}
.contact-role{font-size:11px;color:var(--muted);margin-top:1px;}
.contact-status{
  font-size:10px;padding:3px 9px;border-radius:20px;
  font-family:var(--mono);
}
.status-on{background:rgba(0,229,180,0.1);color:var(--teal);border:1px solid rgba(0,229,180,0.2);}
.status-off{background:var(--card2);color:var(--muted2);}
.nfc-card-ui{
  background:linear-gradient(135deg,var(--card2),var(--card));
  border:1px solid var(--teal3);border-radius:var(--r);
  padding:20px;margin-bottom:14px;position:relative;overflow:hidden;
}
.nfc-card-ui::before{
  content:'';position:absolute;top:-40px;right:-40px;
  width:140px;height:140px;border-radius:50%;
  border:1px solid rgba(0,229,180,0.08);
}
.nfc-card-ui::after{
  content:'';position:absolute;top:-60px;right:-60px;
  width:200px;height:200px;border-radius:50%;
  border:1px solid rgba(0,229,180,0.04);
}
.nfc-tag{font-family:var(--mono);font-size:10px;color:var(--teal);letter-spacing:0.15em;margin-bottom:14px;display:flex;align-items:center;gap:8px;}
.nfc-field-row{display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border);}
.nfc-field-row:last-child{border-bottom:none;}
.nfc-field-label{font-size:12px;color:var(--muted);}
.nfc-field-val{font-size:12px;color:var(--white);font-weight:500;}

/* ── RING FINDER ── */
.finder-card{
  background:var(--card);border:1px solid var(--border);
  border-radius:var(--r);padding:20px;margin-bottom:14px;
}
.finder-status{
  display:flex;align-items:center;gap:10px;margin-bottom:16px;
}
.finder-methods{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:14px;}
.finder-method{
  background:var(--card2);border-radius:10px;
  padding:12px 8px;text-align:center;
  border:1px solid var(--border);cursor:pointer;transition:all 0.2s;
}
.finder-method.active{border-color:var(--teal2);background:rgba(0,229,180,0.06);}
.fm-icon{font-size:20px;margin-bottom:4px;}
.fm-label{font-size:10px;color:var(--muted);}
.ping-btn{
  width:100%;padding:13px;border-radius:10px;
  background:rgba(0,229,180,0.08);
  border:1px solid rgba(0,229,180,0.25);
  color:var(--teal);font-size:13px;font-weight:500;
  font-family:var(--sans);cursor:pointer;
  transition:all 0.2s;letter-spacing:0.03em;
}
.ping-btn:hover{background:rgba(0,229,180,0.15);border-color:var(--teal2);}
.ping-btn:active{transform:scale(0.98);}

/* ── TEAM DASHBOARD ── */
.team-member{
  display:flex;align-items:center;gap:12px;
  padding:14px;background:var(--card);
  border:1px solid var(--border);border-radius:var(--r2);
  margin-bottom:8px;transition:border-color 0.2s;
}
.team-member:hover{border-color:var(--border2);}
.member-av{
  width:36px;height:36px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:12px;font-weight:500;color:var(--white);
  flex-shrink:0;font-family:var(--mono);
}
.member-info{flex:1;}
.member-name{font-size:13px;font-weight:500;color:var(--white);}
.member-role{font-size:11px;color:var(--muted);margin-top:1px;}
.member-scores{display:flex;gap:6px;}
.mini-score{
  font-family:var(--mono);font-size:11px;
  padding:2px 7px;border-radius:6px;
  background:var(--card2);border:1px solid var(--border);
}
.risk-badge{
  font-size:10px;padding:3px 8px;border-radius:20px;
  font-family:var(--mono);white-space:nowrap;
}
.risk-low{background:rgba(0,229,180,0.1);color:var(--teal);}
.risk-med{background:rgba(245,166,35,0.1);color:var(--amber);}
.risk-high{background:rgba(255,79,79,0.1);color:var(--red);}

/* ── TOGGLES ── */
.toggle-row{
  display:flex;align-items:center;justify-content:space-between;
  padding:14px 16px;background:var(--card);
  border:1px solid var(--border);border-radius:var(--r2);
  margin-bottom:8px;
}
.toggle-left{display:flex;align-items:center;gap:12px;}
.toggle-icon{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;}
.toggle-icon svg{width:16px;height:16px;}
.toggle-title{font-size:13px;font-weight:500;color:var(--white);}
.toggle-desc{font-size:11px;color:var(--muted);margin-top:1px;}
.toggle{
  width:44px;height:24px;border-radius:12px;
  background:var(--card2);border:none;cursor:pointer;
  position:relative;transition:background 0.25s;flex-shrink:0;
}
.toggle.on{background:var(--teal3);}
.toggle::after{
  content:'';position:absolute;
  top:3px;left:3px;width:18px;height:18px;
  border-radius:50%;background:var(--muted2);
  transition:transform 0.25s,background 0.25s;
}
.toggle.on::after{transform:translateX(20px);background:#fff;}

/* ── THRESHOLD SLIDER ── */
.threshold-card{
  background:var(--card);border:1px solid var(--border);
  border-radius:var(--r);padding:18px;margin-bottom:14px;
}
.slider-wrap{margin-top:10px;}
input[type=range]{
  width:100%;height:4px;border-radius:2px;
  -webkit-appearance:none;background:var(--card2);outline:none;cursor:pointer;
  background:linear-gradient(to right, var(--teal) var(--pct, 85%), var(--card2) var(--pct, 85%));
}
input[type=range]::-webkit-slider-thumb{
  -webkit-appearance:none;width:18px;height:18px;
  border-radius:50%;background:var(--teal);cursor:pointer;
  border:2px solid var(--bg);box-shadow:0 0 8px rgba(0,229,180,0.4);
}
.slider-labels{display:flex;justify-content:space-between;font-size:10px;color:var(--muted2);margin-top:6px;}

/* ── PROFILE / SETTINGS ── */
.settings-section{margin-bottom:20px;}
.settings-section-title{font-family:var(--mono);font-size:10px;color:var(--teal);letter-spacing:0.1em;margin-bottom:10px;}
.profile-header{
  display:flex;align-items:center;gap:16px;
  padding:20px;background:var(--card);border:1px solid var(--border);
  border-radius:var(--r);margin-bottom:14px;
}
.profile-av{
  width:56px;height:56px;border-radius:50%;
  background:linear-gradient(135deg,var(--teal4),var(--teal3));
  display:flex;align-items:center;justify-content:center;
  font-size:18px;font-weight:700;font-family:var(--mono);color:var(--teal);
  flex-shrink:0;
}
.profile-name{font-size:18px;font-weight:500;color:var(--white);}
.profile-sub{font-size:12px;color:var(--muted);margin-top:3px;}
.profile-tag{
  font-family:var(--mono);font-size:10px;
  background:rgba(0,229,180,0.1);color:var(--teal);
  padding:3px 8px;border-radius:20px;
  border:1px solid rgba(0,229,180,0.2);margin-top:6px;display:inline-block;
}
.stat-mini-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px;}
.stat-mini{
  background:var(--card);border:1px solid var(--border);
  border-radius:10px;padding:12px;text-align:center;
}
.stat-mini-val{font-family:var(--mono);font-size:20px;font-weight:700;color:var(--teal);}
.stat-mini-label{font-size:10px;color:var(--muted);margin-top:3px;}

/* ── CHART CANVAS ── */
canvas{display:block;width:100%!important;}

/* ── TOOLTIP ── */
.tooltip{
  position:fixed;z-index:100;
  background:var(--card2);border:1px solid var(--border2);
  border-radius:8px;padding:8px 12px;
  font-size:11px;color:var(--white);
  pointer-events:none;opacity:0;transition:opacity 0.15s;
  font-family:var(--mono);
}
.tooltip.show{opacity:1;}

/* ── ANIMATIONS ── */
@keyframes fade-up{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}
.fade-in{animation:fade-up 0.4s ease both;}
.delay-1{animation-delay:0.05s;}
.delay-2{animation-delay:0.1s;}
.delay-3{animation-delay:0.15s;}
.delay-4{animation-delay:0.2s;}
.delay-5{animation-delay:0.25s;}
.delay-6{animation-delay:0.3s;}

/* ── NOTIFICATION DRAWER ── */
.notif-drawer{
  position:fixed;top:60px;right:0;bottom:0;width:320px;
  background:var(--bg2);border-left:1px solid var(--border);
  z-index:50;transform:translateX(100%);transition:transform 0.3s cubic-bezier(0.4,0,0.2,1);
  overflow-y:auto;padding:20px;
}
.notif-drawer.open{transform:translateX(0);}
.notif-header{font-family:var(--mono);font-size:12px;color:var(--teal);letter-spacing:0.1em;margin-bottom:16px;}
.notif-item{
  padding:12px 14px;background:var(--card);border:1px solid var(--border);
  border-radius:var(--r2);margin-bottom:8px;
}
.notif-item-title{font-size:13px;font-weight:500;color:var(--white);}
.notif-item-sub{font-size:11px;color:var(--muted);margin-top:3px;}
.notif-item-time{font-size:10px;color:var(--muted2);font-family:var(--mono);margin-top:4px;}

/* ── RESPONSIVE ── */
@media(max-width:900px){
  .grid-3{grid-template-columns:1fr 1fr;}
  .grid-4{grid-template-columns:1fr 1fr;}
  .sound-grid{grid-template-columns:repeat(4,1fr);}
